#
# Stellux Kernel Configuration - AArch64 Architecture
#
# Architecture-specific settings only.
# Common settings are in config.mk (project root).
#

# ============================================================================
# Architecture
# ============================================================================

ARCH := aarch64

# ============================================================================
# AArch64-Specific Compiler Flags
# ============================================================================

CXXFLAGS_ARCH := \
	--target=aarch64-unknown-none \
	-mgeneral-regs-only

# ============================================================================
# AArch64-Specific Assembly Flags
# ============================================================================

ASFLAGS_ARCH := \
	--target=aarch64-unknown-none

# ============================================================================
# Linker Script
# ============================================================================

LINKER_SCRIPT := arch/aarch64/linker.ld

#
# Stellux Kernel Configuration - x86_64 Architecture
#
# Architecture-specific settings only.
# Common settings are in config.mk.
#

# ============================================================================
# Architecture
# ============================================================================

ARCH := x86_64

# ============================================================================
# x86_64-Specific Compiler Flags
# ============================================================================

CXXFLAGS_ARCH := \
	--target=x86_64-unknown-none \
	-mno-red-zone \
	-mno-sse \
	-mno-sse2 \
	-mno-mmx \
	-mno-80387 \
	-mcmodel=kernel

# ============================================================================
# x86_64-Specific Assembly Flags
# ============================================================================

ASFLAGS_ARCH := \
	--target=x86_64-unknown-none

# ============================================================================
# Linker Script
# ============================================================================

LINKER_SCRIPT := arch/x86_64/linker.ld

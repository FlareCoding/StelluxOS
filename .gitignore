# Build artifacts
build/
*.o
*.elf

# Generated images
images/*.img
images/*.iso

# Downloaded Limine binaries (reproducible via make limine)
boot/limine/*.EFI
boot/limine/limine

# Downloaded RPi4 UEFI firmware (reproducible via make rpi4-firmware)
boot/rpi4-uefi/*
!boot/rpi4-uefi/config.txt

# Editor/IDE
.vscode/
.idea/
*.swp
*~

# Clangd
.cache/
compile_commands.json

# Userland build artifacts
userland/sysroot/
userland/musl-*
userland/build/
initrd/bin/*
!initrd/bin/.gitkeep

# OS files
.DS_Store
Thumbs.db

# DOOM WAD file (downloadable via 'make doom-wad')
initrd/etc/res/doom/doom1.wad
